<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CinemaSessionManager.MauiApp.Pages.SessionDetailsPage"
             Title="{Binding Session.MovieTitle}"
             BackgroundColor="{StaticResource BackgroundColor}">

    <Grid RowDefinitions="*">

        <ScrollView IsEnabled="{Binding IsNotBusy}">
            <VerticalStackLayout Margin="16" Spacing="8">

                <!-- Кнопки керування сеансом -->
                <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                    <Button Text="Редагувати"
                            Command="{Binding EditCommand}"
                            BackgroundColor="{StaticResource PrimaryColor}"
                            TextColor="White"
                            FontSize="14"
                            HeightRequest="36"
                            CornerRadius="8"
                            IsVisible="{Binding IsNotEditing}" />
                    <Button Text="Видалити"
                            Command="{Binding DeleteCommand}"
                            BackgroundColor="{StaticResource AccentColor}"
                            TextColor="White"
                            FontSize="14"
                            HeightRequest="36"
                            CornerRadius="8"
                            IsVisible="{Binding IsNotEditing}" />
                </HorizontalStackLayout>

                <!-- Режим перегляду -->
                <Border BackgroundColor="{StaticResource CardColor}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        Padding="24,20"
                        IsVisible="{Binding IsNotEditing}">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="{Binding Session.MovieTitle}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimaryColor}"
                               Margin="0,0,0,16" />

                        <Grid ColumnDefinitions="140, *" Margin="0,0,0,12">
                            <Label Grid.Column="0" Text="Кінозал:"
                                   FontAttributes="Bold" FontSize="14"
                                   TextColor="{StaticResource TextSecondaryColor}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Session.HallName}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimaryColor}" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Opacity="0.5" Margin="0,4" />

                        <Grid ColumnDefinitions="140, *" Margin="0,12,0,12">
                            <Label Grid.Column="0" Text="Жанр:"
                                   FontAttributes="Bold" FontSize="14"
                                   TextColor="{StaticResource TextSecondaryColor}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Session.Genre}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimaryColor}" />
                        </Grid>

                        <Grid ColumnDefinitions="140, *" Margin="0,0,0,12">
                            <Label Grid.Column="0" Text="Рік випуску:"
                                   FontAttributes="Bold" FontSize="14"
                                   TextColor="{StaticResource TextSecondaryColor}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Session.ReleaseYear}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimaryColor}" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Opacity="0.5" Margin="0,4" />

                        <Grid ColumnDefinitions="140, *" Margin="0,12,0,12">
                            <Label Grid.Column="0" Text="Початок:"
                                   FontAttributes="Bold" FontSize="14"
                                   TextColor="{StaticResource TextSecondaryColor}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Session.StartTime, StringFormat='{0:HH:mm}'}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimaryColor}" />
                        </Grid>

                        <Grid ColumnDefinitions="140, *" Margin="0,0,0,12">
                            <Label Grid.Column="0" Text="Тривалість:"
                                   FontAttributes="Bold" FontSize="14"
                                   TextColor="{StaticResource TextSecondaryColor}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Session.DurationMinutes, StringFormat='{0} хв'}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimaryColor}" />
                        </Grid>

                        <Grid ColumnDefinitions="140, *" Margin="0,0,0,4">
                            <Label Grid.Column="0" Text="Завершення:"
                                   FontAttributes="Bold" FontSize="14"
                                   TextColor="{StaticResource TextSecondaryColor}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Session.EndTime, StringFormat='{0:HH:mm}'}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimaryColor}" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Режим редагування -->
                <Border BackgroundColor="{StaticResource CardColor}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource PrimaryColor}"
                        StrokeThickness="2"
                        Padding="24,20"
                        IsVisible="{Binding IsEditing}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Редагування сеансу" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}" />

                        <Label Text="Назва фільму:" FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Entry Text="{Binding EditMovieTitle}"
                               Placeholder="Назва фільму" />

                        <Label Text="Жанр:" FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Picker ItemsSource="{Binding GenreOptions}"
                                SelectedIndex="{Binding EditGenreIndex}" />

                        <Label Text="Рік випуску:" FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Entry Text="{Binding EditReleaseYearText}"
                               Placeholder="Рік випуску"
                               Keyboard="Numeric" />

                        <Label Text="Час початку:" FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <TimePicker Time="{Binding EditStartTime}" />

                        <Label Text="Тривалість (хв):" FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Entry Text="{Binding EditDurationText}"
                               Placeholder="Тривалість у хвилинах"
                               Keyboard="Numeric" />

                        <HorizontalStackLayout Spacing="10" HorizontalOptions="End" Margin="0,8,0,0">
                            <Button Text="Зберегти"
                                    Command="{Binding SaveCommand}"
                                    BackgroundColor="{StaticResource PrimaryColor}"
                                    TextColor="White"
                                    CornerRadius="8" />
                            <Button Text="Скасувати"
                                    Command="{Binding CancelEditCommand}"
                                    BackgroundColor="#888"
                                    TextColor="White"
                                    CornerRadius="8" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Overlay індикатор завантаження -->
        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="#44000000">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource PrimaryColor}"
                               HeightRequest="50"
                               WidthRequest="50"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>

    </Grid>
</ContentPage>
