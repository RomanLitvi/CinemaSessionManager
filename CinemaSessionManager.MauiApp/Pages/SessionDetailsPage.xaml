<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CinemaSessionManager.MauiApp.Pages.SessionDetailsPage"
             Title="Деталі сеансу"
             BackgroundColor="{StaticResource BackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Margin="16" Spacing="8">

            <!-- Назва фільму -->
            <Label x:Name="MovieTitleLabel"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimaryColor}"
                   Margin="4,8,4,12" />

            <!-- Деталі сеансу -->
            <Border BackgroundColor="{StaticResource CardColor}"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1"
                    Padding="24,20">
                <VerticalStackLayout Spacing="0">

                    <!-- Кінозал -->
                    <Grid ColumnDefinitions="160, *" Margin="0,0,0,12">
                        <Label Grid.Column="0" Text="Кінозал:"
                               FontAttributes="Bold" FontSize="14"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Label Grid.Column="1" x:Name="HallNameLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimaryColor}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Opacity="0.5" Margin="0,4" />

                    <!-- Жанр -->
                    <Grid ColumnDefinitions="160, *" Margin="0,12,0,12">
                        <Label Grid.Column="0" Text="Жанр:"
                               FontAttributes="Bold" FontSize="14"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Label Grid.Column="1" x:Name="GenreLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimaryColor}" />
                    </Grid>

                    <!-- Рік випуску -->
                    <Grid ColumnDefinitions="160, *" Margin="0,0,0,12">
                        <Label Grid.Column="0" Text="Рік випуску:"
                               FontAttributes="Bold" FontSize="14"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Label Grid.Column="1" x:Name="ReleaseYearLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimaryColor}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Opacity="0.5" Margin="0,4" />

                    <!-- Час початку -->
                    <Grid ColumnDefinitions="160, *" Margin="0,12,0,12">
                        <Label Grid.Column="0" Text="Початок:"
                               FontAttributes="Bold" FontSize="14"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Label Grid.Column="1" x:Name="StartTimeLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimaryColor}" />
                    </Grid>

                    <!-- Тривалість -->
                    <Grid ColumnDefinitions="160, *" Margin="0,0,0,12">
                        <Label Grid.Column="0" Text="Тривалість:"
                               FontAttributes="Bold" FontSize="14"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Label Grid.Column="1" x:Name="DurationLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimaryColor}" />
                    </Grid>

                    <!-- Час завершення -->
                    <Grid ColumnDefinitions="160, *" Margin="0,0,0,4">
                        <Label Grid.Column="0" Text="Завершення:"
                               FontAttributes="Bold" FontSize="14"
                               TextColor="{StaticResource TextSecondaryColor}" />
                        <Label Grid.Column="1" x:Name="EndTimeLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimaryColor}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
